{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "baseUrl": ".",
    "paths": {
      "@memo-inbox/shared-types": [
        "packages/shared-types/src/index.ts"
      ],
      "@memo-inbox/api-client": [
        "packages/api-client/src/index.ts"
      ],
      "@memo-inbox/editor-markdown": [
        "packages/editor-markdown/src/index.ts"
      ],
      "@memo-inbox/platform-bridge": [
        "packages/platform-bridge/src/index.ts"
      ],
      "@memo-inbox/ui-kit": [
        "packages/ui-kit/src/index.ts"
      ],
      "@memo-inbox/app-core": [
        "packages/app-core/src/index.ts"
      ],
      "@memo-inbox/tooling-config": [
        "packages/tooling-config/src/index.ts"
      ]
    }
  }
}
